PORT=5173

# MongoDB Atlas connection string. Local JSON storage is used when this is empty.
DATABASE_URL=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=soft_skill_dashboard

# SMTP settings. data/mailbox.json fallback is used when these are empty.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
